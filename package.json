{
	"name": "dimrill",
	"version": "5.3.0",
	"description": "Dimrill V5",
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"require": "./dist/cjs/index.js",
			"import": "./dist/esm/index.js",
			"default": "./dist/esm/index.js"
		},
		"./types": {
			"types": "./dist/types/types/index.d.ts"
		}
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"dev": "tsc --build && node ./examples/index.js && tsc --build --clean",
		"compile": "tsc -b ./tsconfig.cjs.json ./tsconfig.esm.json ./tsconfig.types.json",
		"build:clean": "rm -rf ./dist",
		"build": "npm-run-all build:clean compile prepare-package",
		"prepare-package": "node ./scripts/prepare-package-json",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"clean": "tsc --build --clean",
		"lint": "biome lint src tests",
		"format": "biome format --write src tests"
	},
	"license": "MIT",
	"keywords": [
		"authorization",
		"authorizer",
		"jwt",
		"mongoose",
		"fastify",
		"express"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sosickstudio/dimrill.git"
	},
	"author": "Mateo Laporte",
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@jest/test-sequencer": "^30.4.1",
		"@swc/core": "^1.15.43",
		"@swc/jest": "^0.2.39",
		"@types/jest": "^30.0.0",
		"@types/lodash": "^4.17.24",
		"@types/node": "^26.1.1",
		"jest": "^30.4.2",
		"npm-run-all": "^4.1.5",
		"tsx": "^4.23.0",
		"typescript": "^7.0.2"
	},
	"dependencies": {
		"bson": "^7.3.1",
		"lodash": "^4.18.1"
	}
}
